#!/usr/bin/env bash
# roundtable -- a tiny, dependency-light relay for a 3-party agent workflow.
#
#   you (arbiter) + Claude Code (玄 / lead wire) + Codex (素 / impl wire)
#
# It does ONE thing: removes the copy-paste between the two CLI panes by
# relaying mailbox-file writes between them (see bin/relay.py). It never
# touches the agents' model loop or native abilities.
#
# Subcommands (`rt` is shorthand for `roundtable`):
#   rt new [--start] <name> create a named idea worktree
#   rt init [name|dir]      scaffold docs/design/roundtable/ + .roundtable/
#   rt start [name|dir]     launch the workbench
#   rt stop [name|dir]      stop this project's session
#   rt kickoff [name] [xuan|su] re-send kickoff prompts (lead|impl legacy aliases)
#   rt list                 list running roundtable sessions
#   rt selftest             verify relay/layout/key checks on this machine (no real CLIs needed)
#
# Env overrides:
#   CLAUDE_CMD (default: claude)   command to start the 玄 CLI
#   CODEX_CMD  (default: codex)    command to start the 素 CLI
#   SESSION    (default: per-project roundtable-<name>-<hash>)
#   RT_LAYOUT  (default: workbench)  workbench = 4 panes; classic = old 2 panes + relay window
#   RT_MOUSE   (default: 0)        enable tmux mouse at start (off by default; toggle in-session with prefix+RT_MOUSE_KEY)
#   RT_KEYS    (default: 1)        install/use roundtable keybindings for this session (0 = no-op in session)
#   RT_TIPS_KEY (default: g)       tmux prefix key for the roundtable tips popup
#   RT_FILE_KEY (default: e)       tmux prefix key for the project file-view popup
#   RT_MOUSE_KEY (default: v)      tmux prefix key that toggles tmux mouse mode on/off
#   AUTO_KICKOFF    (default: 1)   auto-send each pane its contract once the CLI is settled (0 = manual)
#   KICKOFF_TIMEOUT (default: 30)  max seconds to wait per pane before giving up on auto-kickoff
#
# Default layout: top 玄 | 素, bottom command shell | relay watcher.
# Prior behavior: RT_LAYOUT=classic roundtable start (mouse is now off by default).
# Keys: prefix+g tips, prefix+e file view, prefix+v toggle mouse; RT_KEYS=0 or RT_*_KEY overrides.
# If the visible relay pane is killed, recover with roundtable stop && roundtable start.
set -euo pipefail

TOOL_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# SESSION empty => derived per-project (one roundtable per project, runnable concurrently).
# Set SESSION in the environment to override.
SESSION="${SESSION:-}"
CLAUDE_CMD="${CLAUDE_CMD:-claude}"
CODEX_CMD="${CODEX_CMD:-codex}"
RT_LAYOUT="${RT_LAYOUT:-workbench}"
RT_MOUSE="${RT_MOUSE:-0}"
RT_KEYS="${RT_KEYS:-1}"
RT_TIPS_KEY="${RT_TIPS_KEY:-g}"
RT_FILE_KEY="${RT_FILE_KEY:-e}"
RT_MOUSE_KEY="${RT_MOUSE_KEY:-v}"
# Auto-kickoff: send each pane its operating-contract prompt once its CLI looks settled.
# Set AUTO_KICKOFF=0 to keep the old manual paste. KICKOFF_TIMEOUT caps the per-pane wait.
AUTO_KICKOFF="${AUTO_KICKOFF:-1}"
KICKOFF_TIMEOUT="${KICKOFF_TIMEOUT:-30}"

die() { echo "roundtable: $*" >&2; exit 1; }

_shell_quote() {
  local value="${1//\'/\'\\\'\'}"
  printf "'%s'" "$value"
}

_pane_belongs_to_session() {
  local sess="$1" pane="$2" pane_session
  [ -n "$sess" ] && [ -n "$pane" ] || return 1
  tmux has-session -t "$sess" 2>/dev/null || return 1
  pane_session="$(tmux display-message -p -t "$pane" '#{session_name}' 2>/dev/null)" || return 1
  [ "$pane_session" = "$sess" ]
}

_require_pane_in_session() {
  local sess="$1" pane="$2"
  if ! _pane_belongs_to_session "$sess" "$pane"; then
    die "pane '$pane' is stale or outside session '$sess' -- restart the session"
  fi
}

# Wait until a pane's CLI output looks settled: non-empty output that holds
# steady for several ~1s samples after a minimum elapsed time. Loading spinners
# keep the output changing, so we naturally wait them out. This is generic on
# purpose -- no per-CLI prompt-string matching -- and only detects visual
# stability, not whether the CLI is at its main input prompt.
_wait_pane_ready() {
  local pane="$1" timeout="$2" sess="${3:-}" prev="" cur="" i=0 stable=0
  local min_elapsed=5 stable_required=3
  while [ "$i" -lt "$timeout" ]; do
    sleep 1; i=$((i + 1))
    if [ -n "$sess" ] && ! _pane_belongs_to_session "$sess" "$pane"; then
      return 2
    fi
    cur="$(tmux capture-pane -p -t "$pane" 2>/dev/null)" || return 2
    if [ -n "$cur" ] && [ "$cur" = "$prev" ]; then
      stable=$((stable + 1))
      if [ "$i" -ge "$min_elapsed" ] && [ "$stable" -ge "$stable_required" ]; then return 0; fi
    else
      stable=0
    fi
    prev="$cur"
  done
  return 1
}

# Type a multi-line-safe prompt into a pane, then submit (mirrors relay.py's two-step send).
_send_prompt() {
  local pane="$1" text="$2" sess="${3:-}"
  if [ -n "$sess" ]; then
    _pane_belongs_to_session "$sess" "$pane" || return 1
  fi
  tmux send-keys -t "$pane" -l "$text" || return 1
  sleep 0.2
  tmux send-keys -t "$pane" Enter || return 1
}

# Type a command line into a pane and submit it (no inter-key delay) -- used to
# launch the CLIs, where a settle pause and ownership re-check are not wanted.
_send_line() {
  local pane="$1" text="$2"
  tmux send-keys -t "$pane" -l "$text" && tmux send-keys -t "$pane" Enter
}

_new_pane() {
  local label="$1" id
  shift
  if ! id="$(tmux "$@" -P -F '#{pane_id}')"; then
    return 1
  fi
  if [ -z "$id" ]; then
    echo "roundtable: tmux did not report the $label id" >&2
    return 1
  fi
  printf '%s\n' "$id"
}

_relay_command() {
  local sess="$1" rt="$2" lead_pane="$3" impl_pane="$4"
  printf 'SESSION=%s ROUNDTABLE_DIR=%s LEAD_PANE=%s IMPL_PANE=%s python3 %s; echo; echo %s; read _' \
    "$(_shell_quote "$sess")" \
    "$(_shell_quote "$rt")" \
    "$(_shell_quote "$lead_pane")" \
    "$(_shell_quote "$impl_pane")" \
    "$(_shell_quote "$TOOL_ROOT/bin/relay.py")" \
    "$(_shell_quote "[relay stopped] press enter to close")"
}

_role_wire() {
  case "$1" in
    lead|xuan) printf 'lead\n' ;;
    impl|su) printf 'impl\n' ;;
    *) return 1 ;;
  esac
}

_role_contract() {
  case "$(_role_wire "$1")" in
    lead) printf 'xuan.md\n' ;;
    impl) printf 'su.md\n' ;;
  esac
}

_role_display() {
  case "$(_role_wire "$1")" in
    lead) printf '玄\n' ;;
    impl) printf '素\n' ;;
  esac
}

_tmux_supports_display_popup() {
  tmux list-commands 2>/dev/null | awk '$1 == "display-popup" { found = 1 } END { exit !found }'
}

_popup_install_plan() {
  local supported="$1" keys_enabled="$2" tips_key="${3:-}" file_key="${4:-}"
  if [ "$keys_enabled" != "1" ]; then
    printf 'skip-keys\n'
  elif [ -z "$tips_key" ]; then
    printf 'skip-missing-tips\n'
  elif [ -z "$file_key" ]; then
    printf 'skip-missing-file\n'
  elif [ "$supported" != "1" ]; then
    printf 'skip-unsupported\n'
  elif [ "$tips_key" = "$file_key" ]; then
    printf 'skip-samekey\n'
  else
    printf 'install\n'
  fi
}

_popup_binding_action() {
  local existing="${1:-}" sentinel="$2" command="$3"
  if [ -z "$existing" ]; then
    printf 'bind\n'
  elif [[ "$existing" == *"$sentinel"* && "$existing" == *"$command"* ]]; then
    printf 'keep\n'
  elif [[ "$existing" == *"$sentinel"* ]]; then
    printf 'bind\n'
  else
    printf 'skip\n'
  fi
}

# Install one global prefix-key binding with detect-&-preserve (shared by the
# popups and the mouse toggle). Args: key, sentinel, key_env (named in the skip
# hint), label (named in the bind-failure warning), match (text identifying our
# own binding in list-keys; "" matches on the sentinel alone), then the tmux
# command + args to bind. Keeps an existing roundtable binding, refuses to clobber
# a foreign one, and binds otherwise.
_install_prefix_binding() {
  local key="$1" sentinel="$2" key_env="$3" label="$4" match="$5"; shift 5
  [ -n "$key" ] || { echo "roundtable: warning: $key_env is empty; $label not installed" >&2; return 0; }
  local existing action
  existing="$(tmux list-keys -T prefix "$key" 2>/dev/null || true)"
  action="$(_popup_binding_action "$existing" "$sentinel" "$match")"
  case "$action" in
    keep) return 0 ;;
    skip)
      echo "roundtable: warning: prefix+$key is already bound; not overriding it (set $key_env to another key or RT_KEYS=0)" >&2
      return 0
      ;;
  esac
  if ! tmux bind-key -T prefix "$key" "$@"; then
    echo "roundtable: warning: could not bind prefix+$key for $label" >&2
  fi
}

_install_popup_binding() {
  local key="$1" kind="$2" sentinel="rt-popup:$2" key_env command
  case "$kind" in
    tips) key_env="RT_TIPS_KEY" ;;
    file) key_env="RT_FILE_KEY" ;;
  esac
  command="RT_POPUP_SENTINEL=$sentinel $(_shell_quote "$TOOL_ROOT/bin/roundtable") _popup $kind"
  _install_prefix_binding "$key" "$sentinel" "$key_env" "roundtable $kind popup" "$command" \
    display-popup -E -w 80% -h 80% "$command"
}

_install_popup_bindings() {
  local tips_key="$1" file_key="$2" supported=0 plan
  _tmux_supports_display_popup && supported=1
  plan="$(_popup_install_plan "$supported" 1 "$tips_key" "$file_key")"
  case "$plan" in
    install) ;;
    skip-missing-tips)
      echo "roundtable: warning: RT_TIPS_KEY is empty; popup keys not installed" >&2
      return 0
      ;;
    skip-missing-file)
      echo "roundtable: warning: RT_FILE_KEY is empty; popup keys not installed" >&2
      return 0
      ;;
    skip-unsupported)
      echo "roundtable: display-popup unsupported by this tmux; popup keys not installed" >&2
      return 0
      ;;
    skip-samekey)
      echo "roundtable: warning: RT_TIPS_KEY and RT_FILE_KEY both use prefix+$tips_key; popup keys not installed (choose distinct keys)" >&2
      return 0
      ;;
    skip-keys)
      return 0
      ;;
  esac

  _install_popup_binding "$tips_key" tips
  _install_popup_binding "$file_key" file
}

# Bind a prefix key to toggle this session's tmux mouse mode. The 'rt-mouse'
# sentinel lives in the display-message so list-keys can recognize our own
# binding (match "" => detect on the sentinel alone). Gated by RT_KEYS.
_install_mouse_binding() {
  _install_prefix_binding "$1" rt-mouse RT_MOUSE_KEY "the mouse toggle" "" \
    set mouse '\;' display-message "rt-mouse: mouse #{?mouse,on,off}"
}

_mouse_banner_text() {
  local mouse_enabled="$1" mouse_key="$2" keys_enabled="${3:-1}" hint=""
  if [ "$keys_enabled" = "1" ] && [ -n "$mouse_key" ]; then
    hint=" Toggle tmux mouse with prefix+$mouse_key."
  fi
  if [ "$mouse_enabled" -eq 1 ]; then
    printf '  Mouse is ON: wheel/click/drag use tmux (hold Shift/Option for native selection).%s\n' "$hint"
  else
    printf '  Mouse is off; native text selection works as usual.%s\n' "$hint"
  fi
}

# The shared status block printed under every start banner (layout + mouse + relay-recovery).
_status_banner() {
  local layout_banner="$1" mouse_enabled="$2" mouse_key="$3" keys_enabled="$4"
  printf '  %s\n' "$layout_banner"
  _mouse_banner_text "$mouse_enabled" "$mouse_key" "$keys_enabled"
  printf "  Relay stopped or killed? Run 'roundtable stop' then 'roundtable start' to recover handoffs.\n"
}

_popup_option() {
  local name="$1"
  if [ -n "${TMUX_PANE:-}" ]; then
    tmux display-message -p -t "$TMUX_PANE" "#{@$name}" 2>/dev/null && return 0
  fi
  tmux display-message -p "#{@$name}" 2>/dev/null || true
}

_page_or_read() {
  if command -v less >/dev/null 2>&1; then
    {
      cat
      printf '\nPress q to close.\n'
    } | less -R
  else
    cat
    printf '\nPress Enter to close...'
    read -r _ </dev/tty 2>/dev/null || true
  fi
}

_popup_tips_text() {
  local dir="$1" tips_key="$2" file_key="$3" mouse_key="$4"
  cat <<EOF
roundtable tips

Project:
  $dir

Keys:
  prefix+$tips_key  tips
  prefix+$file_key  file view
  prefix+$mouse_key  toggle mouse on/off

Commands:
  rt new [--start] <name> create a named idea worktree
  rt init [name|dir]      scaffold docs/design/roundtable/ + .roundtable/
  rt start [name|dir]     launch the workbench
  rt stop [name|dir]      stop this project's session
  rt kickoff [name] [xuan|su] re-send kickoff prompts (lead|impl legacy aliases)
  rt list                 list running roundtable sessions
  rt selftest             verify relay/layout/key checks

Environment:
  RT_LAYOUT=workbench|classic
  RT_MOUSE=1|0 (start with mouse on; default off)
  RT_KEYS=1|0
  RT_TIPS_KEY=$tips_key
  RT_FILE_KEY=$file_key
  RT_MOUSE_KEY=$mouse_key
  AUTO_KICKOFF=1|0
  KICKOFF_TIMEOUT=30
  CLAUDE_CMD=claude
  CODEX_CMD=codex
  SESSION=<name>

Reminders:
  Detach from tmux: prefix+d
  Relay stopped or killed: rt stop && rt start
  Kickoff mis-fired: rt kickoff [name] [xuan|su]
  Typing does nothing / keys like 'f' show "(jump to forward)"?
    The wheel left you in copy-mode -- press q or Esc to get back to input.
EOF
}

cmd_popup() {
  local kind="${1:-}"
  case "$kind" in tips|file) ;; *) die "usage: roundtable _popup tips|file" ;; esac

  local dir keys tips_key file_key
  dir="$(_popup_option roundtable_dir)"
  keys="$(_popup_option roundtable_keys)"
  if [ -z "$dir" ] || [ "$keys" != "1" ]; then
    echo "roundtable: popup inactive here (not a roundtable session, or RT_KEYS=0 for this session)"
    return 0
  fi
  local mouse_key
  tips_key="$(_popup_option roundtable_tips_key)"
  file_key="$(_popup_option roundtable_file_key)"
  mouse_key="$(_popup_option roundtable_mouse_key)"
  tips_key="${tips_key:-g}"
  file_key="${file_key:-e}"
  mouse_key="${mouse_key:-v}"

  case "$kind" in
    tips)
      _popup_tips_text "$dir" "$tips_key" "$file_key" "$mouse_key" | _page_or_read
      ;;
    file)
      if ! cd "$dir"; then
        echo "roundtable: project directory is unavailable: $dir"
        printf '\nPress Enter to close...'
        read -r _ || true
        return 0
      fi
      if command -v yazi >/dev/null 2>&1; then
        exec yazi .
      elif command -v lf >/dev/null 2>&1; then
        exec lf .
      elif command -v ranger >/dev/null 2>&1; then
        exec ranger .
      elif command -v tree >/dev/null 2>&1; then
        tree . | _page_or_read
      else
        ls -R . | _page_or_read
      fi
      ;;
  esac
}

# Single source of truth for the kickoff prompt.
# role accepts display aliases xuan|su and legacy wire labels lead|impl.
# State-aware: also re-read the durable artifacts so a fresh pane starts clean
# (artifacts are empty templates) or resumes an in-progress project.
_kickoff_text() {
  local role="$1" wire contract display tail
  wire="$(_role_wire "$role")" || die "unknown role: $role"
  contract="$(_role_contract "$wire")"
  display="$(_role_display "$wire")"
  if [ "$wire" = "lead" ]; then
    tail="otherwise ask the arbiter for the idea and start Phase 0."
  else
    tail="otherwise acknowledge and wait."
  fi
  printf 'You are %s. Read .roundtable/prompts/protocol.md then .roundtable/prompts/%s -- that is your operating contract. Restore state from .roundtable/_idea.md, docs/design/roundtable/architecture.md, docs/design/roundtable/flow.md, docs/design/roundtable/requirements.md, docs/design/roundtable/decisions.md, .roundtable/channel.md, and your inbox. If docs/design/roundtable/requirements.md or decisions.md is missing but legacy .roundtable/requirements.md or decisions.md exists, use the legacy file once and migrate it before continuing. Workflow: Phase 0 idea roundtable -> Gate 0; Phase 1 final-form design -> Gate 1; Phase 2 detailed requirements -> Gate 2; Phase 3 build loop. Panels are one-shot internal reviews, not relay participants. If work is already in progress, continue from the last handoff; %s' "$display" "$contract" "$tail"
}

# Stable, unique-per-absolute-path, readable tmux session name for a project dir.
_session_for() {
  local dir="$1" base slug hash
  base="$(basename "$dir")"
  slug="$(printf '%s' "$base" | tr -c 'A-Za-z0-9_-' '-' | sed 's/-\{2,\}/-/g; s/^-//; s/-$//')"
  hash="$(printf '%s' "$dir" | cksum | awk '{printf "%x", $1}' | cut -c1-6)"
  printf 'roundtable-%s-%s' "${slug:-proj}" "$hash"
}

_validate_idea_name() {
  local name="${1:-}"
  [[ "$name" =~ ^[A-Za-z0-9][A-Za-z0-9._-]*$ ]] || return 1
  [[ "$name" != .* ]] || return 1
  [[ "$name" != *"/"* ]] || return 1
}

_repo_root() {
  git -C "${1:-$PWD}" rev-parse --show-toplevel 2>/dev/null
}

_source_is_clean() {
  local root="$1"
  [ -z "$(git -C "$root" status --porcelain --untracked-files=no)" ]
}

_branch_exists() {
  local root="$1" branch="$2"
  git -C "$root" show-ref --verify --quiet "refs/heads/$branch"
}

_looks_like_dir_arg() {
  local arg="${1:-}"
  [ -n "$arg" ] || return 1
  [[ "$arg" == */* ]] || [ -d "$arg" ]
}

_worktree_for_name() {
  local name="$1" root base parent
  _validate_idea_name "$name" || die "invalid idea name '$name' (use [A-Za-z0-9][A-Za-z0-9._-]*; no leading dot, spaces, or slashes)"
  root="$(_repo_root "$PWD")" || die "not inside a git worktree"
  base="$(basename "$root")"
  if [[ "$base" == *."$name" ]]; then
    printf '%s\n' "$root"
    return 0
  fi
  parent="$(dirname "$root")"
  printf '%s/%s.%s\n' "$parent" "$base" "$name"
}

_target_from_arg() {
  local arg="${1:-}"
  if [ -z "$arg" ]; then
    printf '%s\n' "$PWD"
  elif _looks_like_dir_arg "$arg"; then
    (cd "$arg" && pwd)
  else
    _worktree_for_name "$arg"
  fi
}

cmd_new() {
  local start_after=0 name="${1:-}"
  if [ "$name" = "--start" ]; then
    start_after=1
    shift
    name="${1:-}"
  fi
  [ -n "$name" ] || die "usage: roundtable new [--start] <name>"
  [ "$#" -eq 1 ] || die "usage: roundtable new [--start] <name>"
  _validate_idea_name "$name" || die "invalid idea name '$name' (use [A-Za-z0-9][A-Za-z0-9._-]*; no leading dot, spaces, or slashes)"

  local root branch wt
  root="$(_repo_root "$PWD")" || die "not inside a git worktree"
  _source_is_clean "$root" || die "source worktree has uncommitted tracked changes; commit or stash before 'roundtable new $name'"
  branch="codex/$name"
  _branch_exists "$root" "$branch" && die "branch '$branch' already exists"
  wt="$(_worktree_for_name "$name")"
  [ ! -e "$wt" ] || die "worktree path already exists: $wt"

  if ! git -C "$root" worktree add -b "$branch" "$wt" HEAD; then
    die "could not create worktree $wt"
  fi
  if ! rm -rf "$wt/.roundtable" "$wt/docs/design/roundtable"; then
    git -C "$root" worktree remove --force "$wt" >/dev/null 2>&1 || true
    git -C "$root" branch -D "$branch" >/dev/null 2>&1 || true
    die "could not reset roundtable state in $wt"
  fi
  if ! "$TOOL_ROOT/bin/roundtable" init "$wt"; then
    git -C "$root" worktree remove --force "$wt" >/dev/null 2>&1 || true
    git -C "$root" branch -D "$branch" >/dev/null 2>&1 || true
    die "could not initialize roundtable in $wt"
  fi
  echo "Created idea '$name'"
  echo "Branch:   $branch"
  echo "Worktree: $wt"
  if [ "$start_after" -eq 1 ]; then
    cmd_start "$wt"
  else
    echo "Next:     roundtable start $name"
  fi
}

cmd_init() {
  local target
  target="$(_target_from_arg "${1:-}")" || die "no such directory or named worktree: ${1:-$PWD}"
  [ -d "$target" ] || die "no such directory or named worktree: $target"
  local rt="$target/.roundtable"
  local design="$target/docs/design/roundtable"
  mkdir -p "$rt/prompts" "$design"

  # Tracked design artifacts (do not clobber if they already exist).
  [ -f "$design/architecture.md" ] || cp "$TOOL_ROOT/templates/architecture.md" "$design/architecture.md"
  [ -f "$design/flow.md" ]         || cp "$TOOL_ROOT/templates/flow.md"         "$design/flow.md"
  if [ ! -f "$design/requirements.md" ]; then
    if [ -f "$rt/requirements.md" ]; then
      cp "$rt/requirements.md" "$design/requirements.md"
    else
      cp "$TOOL_ROOT/templates/requirements.md" "$design/requirements.md"
    fi
  fi
  if [ ! -f "$design/decisions.md" ]; then
    if [ -f "$rt/decisions.md" ]; then
      cp "$rt/decisions.md" "$design/decisions.md"
    else
      cp "$TOOL_ROOT/templates/decisions.md" "$design/decisions.md"
    fi
  fi

  # Runtime handoff state (do not clobber durable history).
  [ -f "$rt/_idea.md" ]   || printf '# Direction\n\n<Phase 0 direction statement; Gate 0 lock goes here.>\n' > "$rt/_idea.md"
  [ -f "$rt/channel.md" ] || cp "$TOOL_ROOT/templates/channel.md" "$rt/channel.md"

  # Mailboxes (transient) + role contracts (always refreshed from the tool).
  : > "$rt/to-lead.md"
  : > "$rt/to-impl.md"
  rm -f "$rt/prompts/lead.md" "$rt/prompts/impl.md"
  cp "$TOOL_ROOT/prompts/protocol.md" "$rt/prompts/protocol.md"
  cp "$TOOL_ROOT/prompts/xuan.md" "$rt/prompts/xuan.md"
  cp "$TOOL_ROOT/prompts/su.md" "$rt/prompts/su.md"

  cat > "$rt/.gitignore" <<'EOF'
# Runtime relay state -- design artifacts live in docs/design/roundtable/.
_idea.md
channel.md
prompts/
to-lead.md
to-impl.md
panes.env
kickoff-lead.txt
kickoff-impl.txt
*.lock
EOF

  echo "Initialized roundtable in $rt"
  echo "Design artifacts (commit these):  docs/design/roundtable/{architecture,flow,requirements,decisions}.md"
  echo "Runtime state (do not commit):     .roundtable/{_idea,channel,to-*,panes,kickoff,prompts}"
  echo "Next:  cd '$target' && roundtable start"
}

cmd_start() {
  local target
  target="$(_target_from_arg "${1:-}")" || die "no such directory or named worktree: ${1:-$PWD}"
  [ -d "$target" ] || die "no such directory or named worktree: $target"
  local rt="$target/.roundtable"
  [ -d "$rt" ] || die "no .roundtable in $target -- run 'roundtable init' first"
  command -v tmux >/dev/null 2>&1 || die "tmux is required"

  local sess="${SESSION:-$(_session_for "$target")}"
  local layout="$RT_LAYOUT"
  case "$layout" in
    workbench|classic) ;;
    *) die "RT_LAYOUT must be 'workbench' or 'classic' (got '$layout')" ;;
  esac
  if tmux has-session -t "$sess" 2>/dev/null; then
    die "session '$sess' (this project) already exists -- attach with 'tmux attach -t $sess' or 'roundtable stop' first"
  fi

  local session_created=0 mouse_enabled=0 keys_enabled=1
  if [ "$RT_KEYS" = "0" ]; then
    keys_enabled=0
  fi
  start_fail() {
    local message="$1"
    echo "roundtable: $message" >&2
    rm -f "$rt/panes.env"
    if [ "$session_created" -eq 1 ]; then
      tmux kill-session -t "$sess" 2>/dev/null || true
    fi
    exit 1
  }

  rm -f "$rt/panes.env"

  local cols lines
  cols="$(tput cols 2>/dev/null || true)"
  lines="$(tput lines 2>/dev/null || true)"
  case "$cols" in ''|*[!0-9]*) cols=200 ;; esac
  case "$lines" in ''|*[!0-9]*) lines=50 ;; esac
  if [ "$cols" -lt 100 ] || [ "$lines" -lt 30 ]; then
    echo "roundtable: warning: terminal is ${cols}x${lines}; the workbench is best at 100x30 or larger" >&2
  fi

  local lead_pane impl_pane command_pane="" relay_pane
  lead_pane="$(_new_pane "玄 pane" new-session -d -s "$sess" -c "$target" -x "$cols" -y "$lines")" \
    || start_fail "could not create tmux session '$sess'"
  session_created=1

  if [ "$layout" = "workbench" ]; then
    command_pane="$(_new_pane "command pane" split-window -v -l 33% -t "$lead_pane" -c "$target")" \
      || start_fail "could not create command pane"
    impl_pane="$(_new_pane "素 pane" split-window -h -t "$lead_pane" -c "$target")" \
      || start_fail "could not create 素 pane"
    relay_pane="$(_new_pane "relay pane" split-window -h -t "$command_pane" -c "$target")" \
      || start_fail "could not create relay pane"
  else
    impl_pane="$(_new_pane "素 pane" split-window -h -t "$lead_pane" -c "$target")" \
      || start_fail "could not create 素 pane"
    relay_pane="$(_new_pane "relay pane" new-window -t "$sess" -n relay -c "$target")" \
      || start_fail "could not create relay window"
  fi

  tmux select-pane -t "$lead_pane" -T 玄 || start_fail "could not title 玄 pane"
  tmux select-pane -t "$impl_pane" -T 素 || start_fail "could not title 素 pane"
  if [ -n "$command_pane" ]; then
    tmux select-pane -t "$command_pane" -T command || start_fail "could not title command pane"
  fi
  tmux select-pane -t "$relay_pane" -T relay || start_fail "could not title relay pane"
  tmux set-option -t "$sess" pane-border-status top 2>/dev/null || true

  cat > "$rt/panes.env" <<EOF
SESSION=$sess
LEAD_PANE=$lead_pane
IMPL_PANE=$impl_pane
EOF
  tmux set-option -t "$sess" @roundtable_dir "$target" || start_fail "could not set @roundtable_dir"
  tmux set-option -t "$sess" @roundtable_keys "$keys_enabled" || start_fail "could not set @roundtable_keys"
  tmux set-option -t "$sess" @roundtable_tips_key "$RT_TIPS_KEY" || start_fail "could not set @roundtable_tips_key"
  tmux set-option -t "$sess" @roundtable_file_key "$RT_FILE_KEY" || start_fail "could not set @roundtable_file_key"
  tmux set-option -t "$sess" @roundtable_mouse_key "$RT_MOUSE_KEY" || start_fail "could not set @roundtable_mouse_key"
  if [ "$keys_enabled" -eq 1 ]; then
    _install_popup_bindings "$RT_TIPS_KEY" "$RT_FILE_KEY"
    _install_mouse_binding "$RT_MOUSE_KEY"
  fi
  if [ "$RT_MOUSE" != "0" ]; then
    if tmux set-option -t "$sess" mouse on 2>/dev/null; then
      mouse_enabled=1
    else
      echo "roundtable: warning: could not enable tmux mouse mode; continuing" >&2
    fi
  fi

  # Start the relay watcher only after panes.env has the captured pane ids.
  tmux respawn-pane -k -t "$relay_pane" "$(_relay_command "$sess" "$rt" "$lead_pane" "$impl_pane")" \
    || start_fail "could not start relay watcher"

  # Start the two CLIs in their panes.
  _require_pane_in_session "$sess" "$lead_pane"
  _require_pane_in_session "$sess" "$impl_pane"
  _send_line "$lead_pane" "$CLAUDE_CMD" || start_fail "could not start 玄 CLI"
  _send_line "$impl_pane" "$CODEX_CMD" || start_fail "could not start 素 CLI"

  local lead_kick impl_kick
  lead_kick="$(_kickoff_text lead)"
  impl_kick="$(_kickoff_text impl)"
  # Always drop the prompts to files so they can be re-pasted from inside tmux even
  # when auto-send mis-fires (a send can "succeed" yet land in a half-ready pane).
  printf '%s\n' "$lead_kick" > "$rt/kickoff-lead.txt" || start_fail "could not write kickoff-lead.txt"
  printf '%s\n' "$impl_kick" > "$rt/kickoff-impl.txt" || start_fail "could not write kickoff-impl.txt"
  local fallback="If a pane didn't get its kickoff cleanly: re-send with 'roundtable kickoff [name] [xuan|su]' (lead|impl legacy aliases), or copy from .roundtable/kickoff-{lead,impl}.txt"
  local layout_banner
  if [ "$layout" = "workbench" ]; then
    layout_banner="TOP: 玄 (Claude Code) | 素 (Codex)   BOTTOM: command shell | relay watcher"
  else
    layout_banner="LEFT: 玄 (Claude Code)   RIGHT: 素 (Codex)   window 'relay': watcher"
  fi

  if [ "$AUTO_KICKOFF" = "1" ]; then
    local lead_sent=0 impl_sent=0
    echo
    echo "Roundtable session '$sess' is up. Waiting for the CLIs to settle, then sending kickoff..."
    if _wait_pane_ready "$lead_pane" "$KICKOFF_TIMEOUT" "$sess"; then
      if _send_prompt "$lead_pane" "$lead_kick" "$sess"; then
        lead_sent=1
      else
        echo "  (玄 pane send failed -- paste its kickoff manually)"
      fi
    else
      echo "  (玄 pane did not settle in ${KICKOFF_TIMEOUT}s -- paste its kickoff manually)"
    fi
    if _wait_pane_ready "$impl_pane" "$KICKOFF_TIMEOUT" "$sess"; then
      if _send_prompt "$impl_pane" "$impl_kick" "$sess"; then
        impl_sent=1
      else
        echo "  (素 pane send failed -- paste its kickoff manually)"
      fi
    else
      echo "  (素 pane did not settle in ${KICKOFF_TIMEOUT}s -- paste its kickoff manually)"
    fi
    if [ "$lead_sent" -eq 1 ] && [ "$impl_sent" -eq 1 ]; then
    cat <<EOF

Kickoff sent to both panes.
$(_status_banner "$layout_banner" "$mouse_enabled" "$RT_MOUSE_KEY" "$keys_enabled")

$fallback
Now just give your raw idea to the LEFT (玄) pane. The relay takes over from there.
Attaching now (detach with Ctrl-b d; stop with 'roundtable stop').
EOF
    else
      cat <<EOF

Auto-kickoff incomplete. Paste these kickoff prompt(s) manually after the matching pane is ready:
$(_status_banner "$layout_banner" "$mouse_enabled" "$RT_MOUSE_KEY" "$keys_enabled")
EOF
      if [ "$lead_sent" -ne 1 ]; then
        cat <<EOF
  LEFT:
        $lead_kick
EOF
      fi
      if [ "$impl_sent" -ne 1 ]; then
        cat <<EOF
  RIGHT:
        $impl_kick
EOF
      fi
      cat <<EOF

After both panes have their operating contract, give your raw idea to the LEFT (玄) pane.
Attaching now (detach with Ctrl-b d; stop with 'roundtable stop').
EOF
    fi
  else
    cat <<EOF

Roundtable session '$sess' is up.  (AUTO_KICKOFF=0 -- manual kickoff)
$(_status_banner "$layout_banner" "$mouse_enabled" "$RT_MOUSE_KEY" "$keys_enabled")

One-time kickoff:
  1. In the LEFT  玄 pane, once Claude Code is ready, send it:
        $lead_kick
  2. In the RIGHT 素 pane, once Codex is ready, send it:
        $impl_kick
  3. Then give your raw idea to the LEFT (玄) pane. The relay takes over from there.

$fallback
Attaching now (detach with Ctrl-b d; stop with 'roundtable stop').
EOF
  fi
  sleep 1
  tmux select-window -t "$sess:0"
  tmux select-pane -t "$lead_pane"
  tmux attach -t "$sess"
}

cmd_stop() {
  local target
  target="$(_target_from_arg "${1:-}" 2>/dev/null || true)"
  [ -n "$target" ] || target="$PWD"
  # Prefer the exact session this project recorded at start; else derive it.
  local sess="$SESSION" envfile="$target/.roundtable/panes.env"
  if [ -z "$sess" ] && [ -f "$envfile" ]; then
    sess="$(sed -n 's/^SESSION=//p' "$envfile")"
  fi
  [ -n "$sess" ] || sess="$(_session_for "$target")"
  tmux kill-session -t "$sess" 2>/dev/null && echo "stopped '$sess'" || echo "no session '$sess'"
}

# Re-send the kickoff prompt to a running session's panes. Use when auto-kickoff
# mis-fired (landed in a half-ready pane) -- run it once the CLI is fully up.
#   roundtable kickoff                 both panes
#   roundtable kickoff xuan|su         just that pane (lead|impl legacy aliases)
#   roundtable kickoff name xuan|su    named worktree pane
cmd_kickoff() {
  local target="$PWD" only="both" first="${1:-}" second="${2:-}"
  if [ -n "$second" ]; then
    target="$(_target_from_arg "$first")" || die "no such named worktree: $first"
    only="$second"
  elif [ -n "$first" ]; then
    case "$first" in
      both|xuan|lead|su|impl) only="$first" ;;
      *) target="$(_target_from_arg "$first")" || die "no such named worktree: $first" ;;
    esac
  fi
  case "$only" in
    both) ;;
    xuan|lead) only="lead" ;;
    su|impl) only="impl" ;;
    *) die "usage: roundtable kickoff [name] [xuan|su|lead|impl]" ;;
  esac
  local envfile="$target/.roundtable/panes.env"
  [ -f "$envfile" ] || die "no session recorded for this project -- run 'roundtable start' first (from the project dir)"
  local sess lead_pane impl_pane
  sess="$(sed -n 's/^SESSION=//p' "$envfile")"
  lead_pane="$(sed -n 's/^LEAD_PANE=//p' "$envfile")"
  impl_pane="$(sed -n 's/^IMPL_PANE=//p' "$envfile")"
  [ -n "$sess" ] || die "panes.env is missing SESSION -- restart the session"
  [ -n "$lead_pane" ] || die "panes.env is missing LEAD_PANE -- restart the session"
  [ -n "$impl_pane" ] || die "panes.env is missing IMPL_PANE -- restart the session"
  tmux has-session -t "$sess" 2>/dev/null || die "session '$sess' is not running -- 'roundtable start' first"
  if [ "$only" = "lead" ] || [ "$only" = "both" ]; then
    _send_prompt "$lead_pane" "$(_kickoff_text lead)" "$sess" || die "pane '$lead_pane' is stale or outside session '$sess' -- restart the session"
    echo "re-sent kickoff to 玄 ($lead_pane)"
  fi
  if [ "$only" = "impl" ] || [ "$only" = "both" ]; then
    _send_prompt "$impl_pane" "$(_kickoff_text impl)" "$sess" || die "pane '$impl_pane' is stale or outside session '$sess' -- restart the session"
    echo "re-sent kickoff to 素 ($impl_pane)"
  fi
}

cmd_list() {
  local rows
  rows="$(tmux ls 2>/dev/null | grep -E '^roundtable-' || true)"
  if [ -n "$rows" ]; then echo "$rows"; else echo "no roundtable sessions running"; fi
}

_selftest_pass() {
  echo "  [PASS] $1"
}

_selftest_fail() {
  echo "  [FAIL] $1"
  return 1
}

_selftest_assert_eq() {
  local label="$1" expected="$2" actual="$3"
  if [ "$actual" = "$expected" ]; then
    _selftest_pass "$label"
  else
    echo "  [FAIL] $label (expected '$expected', got '$actual')"
    return 1
  fi
}

_selftest_assert_pane_id() {
  local label="$1" pane="$2"
  case "$pane" in
    %*) _selftest_pass "$label" ;;
    *) echo "  [FAIL] $label (expected %N pane id, got '$pane')"; return 1 ;;
  esac
}

_selftest_assert_file() {
  local label="$1" path="$2"
  if [ -f "$path" ]; then
    _selftest_pass "$label"
  else
    echo "  [FAIL] $label (missing '$path')"
    return 1
  fi
}

_selftest_assert_no_file() {
  local label="$1" path="$2"
  if [ ! -e "$path" ]; then
    _selftest_pass "$label"
  else
    echo "  [FAIL] $label (unexpected '$path')"
    return 1
  fi
}

_selftest_assert_contains() {
  local label="$1" path="$2" text="$3"
  if grep -Fq -- "$text" "$path" 2>/dev/null; then
    _selftest_pass "$label"
  else
    echo "  [FAIL] $label (missing '$text' in '$path')"
    return 1
  fi
}

# Verify the relay mechanism end-to-end with throwaway tmux + dummy panes
# (no real CLIs needed). Asserts: handoff reaches channel.md, and the nudge
# keystrokes are delivered to the target pane.
cmd_selftest() {
  command -v tmux >/dev/null 2>&1 || die "tmux is required"
  command -v python3 >/dev/null 2>&1 || die "python3 is required"

  local proj="" legacy_proj="" sess="" rt="" design="" legacy_rt="" legacy_design="" got="" relay_pid="" rc=0
  local git_proj="" git_wt="" git_name="" git_branch="" git_new_output="" git_expected_next=""
  local dirty_proj="" dirty_wt="" dirty_output=""
  local cleanup_proj="" cleanup_name="" cleanup_branch="" cleanup_wt=""
  local lead_pane="" impl_pane="" layout_sess="" foreign_sess=""
  local layout_lead="" layout_impl="" layout_command="" layout_relay="" foreign_pane=""
  local cleanup_done=0
  selftest_cleanup() {
    [ "$cleanup_done" -eq 0 ] || return 0
    cleanup_done=1
    if [ -n "${relay_pid:-}" ]; then
      kill "$relay_pid" 2>/dev/null || true
      wait "$relay_pid" 2>/dev/null || true
    fi
    [ -z "${sess:-}" ] || tmux kill-session -t "$sess" 2>/dev/null || true
    [ -z "${layout_sess:-}" ] || tmux kill-session -t "$layout_sess" 2>/dev/null || true
    [ -z "${foreign_sess:-}" ] || tmux kill-session -t "$foreign_sess" 2>/dev/null || true
    if [ -n "${git_proj:-}" ] && [ -n "${git_wt:-}" ]; then
      git -C "$git_proj" worktree remove --force "$git_wt" >/dev/null 2>&1 || true
    fi
    if [ -n "${cleanup_proj:-}" ] && [ -n "${cleanup_wt:-}" ]; then
      git -C "$cleanup_proj" worktree remove --force "$cleanup_wt" >/dev/null 2>&1 || true
    fi
    if [ -n "${dirty_proj:-}" ] && [ -n "${dirty_wt:-}" ]; then
      git -C "$dirty_proj" worktree remove --force "$dirty_wt" >/dev/null 2>&1 || true
    fi
    [ -z "${proj:-}" ] || rm -rf "$proj"
    [ -z "${legacy_proj:-}" ] || rm -rf "$legacy_proj"
    [ -z "${git_proj:-}" ] || rm -rf "$git_proj"
    [ -z "${git_wt:-}" ] || rm -rf "$git_wt"
    [ -z "${dirty_proj:-}" ] || rm -rf "$dirty_proj"
    [ -z "${dirty_wt:-}" ] || rm -rf "$dirty_wt"
    [ -z "${cleanup_proj:-}" ] || rm -rf "$cleanup_proj"
    [ -z "${cleanup_wt:-}" ] || rm -rf "$cleanup_wt"
  }
  trap selftest_cleanup RETURN EXIT
  proj="$(mktemp -d)"
  legacy_proj="$(mktemp -d)"
  sess="rt_selftest_$$"
  layout_sess="${sess}_layout"
  foreign_sess="${sess}_foreign"
  rt="$proj/.roundtable"
  design="$proj/docs/design/roundtable"
  got="$proj/impl_got.txt"

  cmd_init "$proj" >/dev/null

  legacy_rt="$legacy_proj/.roundtable"
  legacy_design="$legacy_proj/docs/design/roundtable"
  mkdir -p "$legacy_rt/prompts"
  printf 'legacy requirements sentinel\n' > "$legacy_rt/requirements.md"
  printf 'legacy decisions sentinel\n' > "$legacy_rt/decisions.md"
  printf 'stale lead contract\n' > "$legacy_rt/prompts/lead.md"
  printf 'stale impl contract\n' > "$legacy_rt/prompts/impl.md"
  cmd_init "$legacy_proj" >/dev/null

  git_proj="$(mktemp -d)"
  git -C "$git_proj" init -q
  git -C "$git_proj" config user.email selftest@example.invalid
  git -C "$git_proj" config user.name "Roundtable Selftest"
  printf 'source sentinel\n' > "$git_proj/source.txt"
  git -C "$git_proj" add source.txt
  git -C "$git_proj" commit -q -m "init selftest repo"
  cmd_init "$git_proj" >/dev/null
  printf 'source idea sentinel\n' > "$git_proj/.roundtable/_idea.md"
  printf 'source requirements sentinel\n' > "$git_proj/docs/design/roundtable/requirements.md"
  git -C "$git_proj" add docs/design/roundtable .roundtable
  git -C "$git_proj" commit -q -m "commit old roundtable docs"
  git_name="sample"
  git_branch="codex/$git_name"
  git_wt="$(cd "$git_proj" && _worktree_for_name "$git_name")"
  cleanup_proj="$(mktemp -d)"
  git -C "$cleanup_proj" init -q
  git -C "$cleanup_proj" config user.email selftest@example.invalid
  git -C "$cleanup_proj" config user.name "Roundtable Selftest"
  printf 'blocks roundtable reset\n' > "$cleanup_proj/docs"
  git -C "$cleanup_proj" add docs
  git -C "$cleanup_proj" commit -q -m "init cleanup selftest repo"
  cleanup_name="broken"
  cleanup_branch="codex/$cleanup_name"
  cleanup_wt="$(cd "$cleanup_proj" && _worktree_for_name "$cleanup_name")"

  tmux kill-session -t "$sess" 2>/dev/null || true
  tmux kill-session -t "$layout_sess" 2>/dev/null || true
  tmux kill-session -t "$foreign_sess" 2>/dev/null || true
  lead_pane="$(_new_pane "玄 pane" new-session -d -s "$sess" -x 200 -y 50)"
  impl_pane="$(_new_pane "素 pane" split-window -h -t "$lead_pane")"
  # The 素 pane captures whatever is typed into it.
  tmux send-keys -t "$impl_pane" -l "cat > '$got'"; tmux send-keys -t "$impl_pane" Enter

  SESSION="$sess" ROUNDTABLE_DIR="$rt" LEAD_PANE="$lead_pane" IMPL_PANE="$impl_pane" POLL_SECONDS=0.3 \
    python3 "$TOOL_ROOT/bin/relay.py" >/dev/null 2>&1 &
  relay_pid=$!
  sleep 1
  printf 'PHASE: 0\nFROM: lead\nSTATUS: needs-reply\n---\nselftest ping\n' > "$rt/to-impl.md"
  sleep 1.5
  kill "$relay_pid" 2>/dev/null || true
  wait "$relay_pid" 2>/dev/null || true   # reap quietly (suppress job-control notice)
  tmux send-keys -t "$impl_pane" C-d 2>/dev/null || true
  sleep 0.3

  echo "roundtable selftest:"

  _selftest_assert_file "init creates architecture design artifact" "$design/architecture.md" || rc=1
  _selftest_assert_file "init creates flow design artifact" "$design/flow.md" || rc=1
  _selftest_assert_file "init creates docs-side requirements" "$design/requirements.md" || rc=1
  _selftest_assert_file "init creates docs-side decisions" "$design/decisions.md" || rc=1
  _selftest_assert_file "init creates runtime idea file" "$rt/_idea.md" || rc=1
  _selftest_assert_file "init creates runtime channel" "$rt/channel.md" || rc=1
  _selftest_assert_file "init copies protocol contract" "$rt/prompts/protocol.md" || rc=1
  _selftest_assert_file "init copies xuan contract" "$rt/prompts/xuan.md" || rc=1
  _selftest_assert_file "init copies su contract" "$rt/prompts/su.md" || rc=1
  _selftest_assert_contains "requirements template has lifecycle pointer sentinel" "$design/requirements.md" "<!-- rt-lifecycle-pointer -->" || rc=1
  _selftest_assert_contains "requirements template has lifecycle diagram sentinel" "$design/requirements.md" "<!-- rt-lifecycle-diagram -->" || rc=1
  _selftest_assert_contains "requirements template has lifecycle note sentinel" "$design/requirements.md" "<!-- rt-lifecycle-note -->" || rc=1
  _selftest_assert_contains "requirements template default status is pending" "$design/requirements.md" "- **状态:** pending" || rc=1
  _selftest_assert_contains "protocol contains lifecycle heading" "$rt/prompts/protocol.md" "## Requirement Status Lifecycle" || rc=1
  _selftest_assert_no_file "init does not create legacy requirements primary" "$rt/requirements.md" || rc=1
  _selftest_assert_no_file "init does not create legacy decisions primary" "$rt/decisions.md" || rc=1
  _selftest_assert_no_file "init does not copy legacy lead contract" "$rt/prompts/lead.md" || rc=1
  _selftest_assert_no_file "init does not copy legacy impl contract" "$rt/prompts/impl.md" || rc=1
  case "$(_kickoff_text lead)" in
    *".roundtable/prompts/xuan.md"*docs/design/roundtable/requirements.md*) _selftest_pass "玄 kickoff references xuan contract and docs baseline" ;;
    *) _selftest_fail "玄 kickoff references xuan contract and docs baseline" || true; rc=1 ;;
  esac
  case "$(_kickoff_text su)" in
    *".roundtable/prompts/su.md"*docs/design/roundtable/requirements.md*) _selftest_pass "su kickoff alias references su contract and docs baseline" ;;
    *) _selftest_fail "su kickoff alias references su contract and docs baseline" || true; rc=1 ;;
  esac
  _selftest_assert_eq "xuan alias maps to lead wire role" "lead" "$(_role_wire xuan)" || rc=1
  _selftest_assert_eq "su alias maps to impl wire role" "impl" "$(_role_wire su)" || rc=1
  if _validate_idea_name "alpha-1_ok.name"; then
    _selftest_pass "idea name validation accepts safe slug"
  else
    _selftest_fail "idea name validation accepts safe slug" || true; rc=1
  fi
  if _validate_idea_name ".hidden" || _validate_idea_name "bad/name" || _validate_idea_name "bad name"; then
    _selftest_fail "idea name validation rejects unsafe slugs" || true; rc=1
  else
    _selftest_pass "idea name validation rejects unsafe slugs"
  fi
  if git_new_output="$(cd "$git_proj" && cmd_new "$git_name")"; then
    _selftest_pass "new creates named idea worktree"
  else
    _selftest_fail "new creates named idea worktree" || true; rc=1
  fi
  git_expected_next="Next:     roundtable start $git_name"
  if printf '%s\n' "$git_new_output" | grep -Fxq "$git_expected_next"; then
    _selftest_pass "new prints named start next step"
  else
    _selftest_fail "new prints named start next step" || true; rc=1
  fi
  _selftest_assert_file "new worktree has runtime state" "$git_wt/.roundtable/_idea.md" || rc=1
  _selftest_assert_file "new worktree has docs requirements" "$git_wt/docs/design/roundtable/requirements.md" || rc=1
  _selftest_assert_contains "new worktree requirements has default template marker" "$git_wt/docs/design/roundtable/requirements.md" "<!-- rt-lifecycle-pointer -->" || rc=1
  if git -C "$git_proj" show-ref --verify --quiet "refs/heads/$git_branch"; then
    _selftest_pass "new creates idea branch"
  else
    _selftest_fail "new creates idea branch" || true; rc=1
  fi
  if grep -q "source idea sentinel" "$git_proj/.roundtable/_idea.md" &&
     grep -q "source requirements sentinel" "$git_proj/docs/design/roundtable/requirements.md" &&
     ! grep -q "source idea sentinel" "$git_wt/.roundtable/_idea.md" &&
     ! grep -q "source requirements sentinel" "$git_wt/docs/design/roundtable/requirements.md"; then
    _selftest_pass "new keeps source roundtable state isolated"
  else
    _selftest_fail "new keeps source roundtable state isolated" || true; rc=1
  fi
  if (cd "$git_proj" && [ "$(_target_from_arg "$git_name")" = "$git_wt" ]); then
    _selftest_pass "name argument resolves to sibling worktree"
  else
    _selftest_fail "name argument resolves to sibling worktree" || true; rc=1
  fi
  if (cd "$git_wt" && [ "$(_target_from_arg "$git_name")" = "$git_wt" ]); then
    _selftest_pass "name argument resolves to current named worktree"
  else
    _selftest_fail "name argument resolves to current named worktree" || true; rc=1
  fi
  if [ "$(_target_from_arg "$git_wt")" = "$git_wt" ]; then
    _selftest_pass "path argument remains legacy directory target"
  else
    _selftest_fail "path argument remains legacy directory target" || true; rc=1
  fi
  if [ "$(_session_for "$git_wt")" != "$(_session_for "$git_proj")" ]; then
    _selftest_pass "named worktree derives separate session"
  else
    _selftest_fail "named worktree derives separate session" || true; rc=1
  fi
  dirty_proj="$(mktemp -d)"
  git -C "$dirty_proj" init -q
  git -C "$dirty_proj" config user.email selftest@example.invalid
  git -C "$dirty_proj" config user.name "Roundtable Selftest"
  printf 'clean\n' > "$dirty_proj/file.txt"
  git -C "$dirty_proj" add file.txt
  git -C "$dirty_proj" commit -q -m "init dirty repo"
  printf 'dirty\n' > "$dirty_proj/file.txt"
  dirty_wt="$(dirname "$dirty_proj")/$(basename "$dirty_proj").dirty"
  if dirty_output="$(cd "$dirty_proj" && cmd_new dirty 2>&1)"; then
    _selftest_fail "new refuses dirty tracked source" || true; rc=1
  else
    _selftest_pass "new refuses dirty tracked source"
  fi
  case "$dirty_output" in
    *"source worktree has uncommitted tracked changes"*) _selftest_pass "new reports dirty tracked source" ;;
    *) _selftest_fail "new reports dirty tracked source" || true; rc=1 ;;
  esac
  if git -C "$dirty_proj" show-ref --verify --quiet refs/heads/codex/dirty; then
    _selftest_fail "new does not create branch for dirty source" || true; rc=1
  else
    _selftest_pass "new does not create branch for dirty source"
  fi
  if [ -e "$dirty_wt" ]; then
    _selftest_fail "new does not create worktree for dirty source" || true; rc=1
  else
    _selftest_pass "new does not create worktree for dirty source"
  fi
  if (cd "$cleanup_proj" && cmd_new "$cleanup_name" >/dev/null 2>&1); then
    _selftest_fail "new reports reset failure after worktree add" || true
    rc=1
  else
    _selftest_pass "new reports reset failure after worktree add"
  fi
  _selftest_assert_no_file "new removes failed-init worktree" "$cleanup_wt" || rc=1
  if git -C "$cleanup_proj" show-ref --verify --quiet "refs/heads/$cleanup_branch"; then
    _selftest_fail "new deletes failed-init branch" || true; rc=1
  else
    _selftest_pass "new deletes failed-init branch"
  fi
  if grep -q "legacy requirements sentinel" "$legacy_design/requirements.md" 2>/dev/null; then
    _selftest_pass "init migrates legacy requirements to docs"
  else
    echo "  [FAIL] init did not migrate legacy requirements"; rc=1
  fi
  if grep -q "legacy decisions sentinel" "$legacy_design/decisions.md" 2>/dev/null; then
    _selftest_pass "init migrates legacy decisions to docs"
  else
    echo "  [FAIL] init did not migrate legacy decisions"; rc=1
  fi
  _selftest_assert_no_file "init removes stale legacy lead contract" "$legacy_rt/prompts/lead.md" || rc=1
  _selftest_assert_no_file "init removes stale legacy impl contract" "$legacy_rt/prompts/impl.md" || rc=1

  local popup_command popup_existing
  popup_command="RT_POPUP_SENTINEL=rt-popup:tips $(_shell_quote "$TOOL_ROOT/bin/roundtable") _popup tips"
  popup_existing="bind-key -T prefix g display-popup -E -h \"80%\" -w \"80%\" \"$popup_command\""
  _selftest_assert_eq "popup install plan installs when supported" "install" "$(_popup_install_plan 1 1 g e)" || rc=1
  _selftest_assert_eq "popup install plan skips RT_KEYS=0" "skip-keys" "$(_popup_install_plan 1 0 g e)" || rc=1
  _selftest_assert_eq "popup install plan skips empty tips key" "skip-missing-tips" "$(_popup_install_plan 1 1 "" e)" || rc=1
  _selftest_assert_eq "popup install plan skips empty file key" "skip-missing-file" "$(_popup_install_plan 1 1 g "")" || rc=1
  _selftest_assert_eq "popup install plan skips unsupported tmux" "skip-unsupported" "$(_popup_install_plan 0 1 g e)" || rc=1
  _selftest_assert_eq "popup install plan skips same key" "skip-samekey" "$(_popup_install_plan 1 1 x x)" || rc=1
  _selftest_assert_eq "popup binding action binds empty key" "bind" "$(_popup_binding_action "" "rt-popup:tips" "$popup_command")" || rc=1
  _selftest_assert_eq "popup binding action keeps current binding" "keep" "$(_popup_binding_action "$popup_existing" "rt-popup:tips" "$popup_command")" || rc=1
  _selftest_assert_eq "popup binding action refreshes stale own binding" "bind" "$(_popup_binding_action "RT_POPUP_SENTINEL=rt-popup:tips '/tmp/old/bin/roundtable' _popup tips" "rt-popup:tips" "$popup_command")" || rc=1
  _selftest_assert_eq "popup binding action skips foreign binding" "skip" "$(_popup_binding_action "bind-key -T prefix g display-message user-binding" "rt-popup:tips" "$popup_command")" || rc=1
  _selftest_assert_eq "mouse binding action binds empty key" "bind" "$(_popup_binding_action "" "rt-mouse" "")" || rc=1
  _selftest_assert_eq "mouse binding action keeps own binding" "keep" "$(_popup_binding_action 'bind-key -T prefix v set-option mouse \; display-message "rt-mouse: mouse on"' "rt-mouse" "")" || rc=1
  _selftest_assert_eq "mouse binding action skips foreign binding" "skip" "$(_popup_binding_action "bind-key -T prefix v select-pane -m" "rt-mouse" "")" || rc=1

  if grep -q "selftest ping" "$rt/channel.md" 2>/dev/null; then
    _selftest_pass "handoff appended to channel.md (transcript works)"
  else
    echo "  [FAIL] message did not reach channel.md"; rc=1
  fi
  if grep -q "New handoff in .roundtable/to-impl.md" "$got" 2>/dev/null; then
    _selftest_pass "nudge keystrokes delivered to the 素 pane (tmux send-keys works)"
  else
    echo "  [FAIL] 素 pane did not receive the nudge"; rc=1
  fi
  if grep -q ".roundtable/prompts/su.md" "$got" 2>/dev/null && ! grep -q ".roundtable/prompts/impl.md" "$got" 2>/dev/null; then
    _selftest_pass "relay nudge points to su contract"
  else
    echo "  [FAIL] relay nudge did not point to su contract"; rc=1
  fi

  if layout_lead="$(_new_pane "layout 玄 pane" new-session -d -s "$layout_sess" -x 200 -y 50)" &&
    layout_command="$(_new_pane "layout command pane" split-window -v -l 33% -t "$layout_lead")" &&
    layout_impl="$(_new_pane "layout 素 pane" split-window -h -t "$layout_lead")" &&
    layout_relay="$(_new_pane "layout relay pane" split-window -h -t "$layout_command")"; then
    tmux select-pane -t "$layout_lead" -T 玄
    tmux select-pane -t "$layout_impl" -T 素
    tmux select-pane -t "$layout_command" -T command
    tmux select-pane -t "$layout_relay" -T relay
    _selftest_assert_pane_id "workbench captures 玄 %N id" "$layout_lead" || rc=1
    _selftest_assert_pane_id "workbench captures 素 %N id" "$layout_impl" || rc=1
    _selftest_assert_pane_id "workbench captures command %N id" "$layout_command" || rc=1
    _selftest_assert_pane_id "workbench captures relay %N id" "$layout_relay" || rc=1
    _selftest_assert_eq "workbench builds four panes" "4" "$(tmux list-panes -t "$layout_sess" | wc -l | tr -d ' ')" || rc=1
    _selftest_assert_eq "workbench pane titles" "玄 素 command relay" "$(printf '%s %s %s %s' "$(tmux display-message -p -t "$layout_lead" '#{pane_title}')" "$(tmux display-message -p -t "$layout_impl" '#{pane_title}')" "$(tmux display-message -p -t "$layout_command" '#{pane_title}')" "$(tmux display-message -p -t "$layout_relay" '#{pane_title}')")" || rc=1

    foreign_pane="$(_new_pane "foreign pane" new-session -d -s "$foreign_sess" -x 80 -y 24)"
    if _pane_belongs_to_session "$layout_sess" "$layout_lead"; then
      _selftest_pass "shell ownership check accepts owned pane"
    else
      _selftest_fail "shell ownership check accepts owned pane" || true; rc=1
    fi
    if _pane_belongs_to_session "$layout_sess" "$foreign_pane"; then
      _selftest_fail "shell ownership check rejects foreign pane" || true; rc=1
    else
      _selftest_pass "shell ownership check rejects foreign pane"
    fi
    if _send_prompt "$foreign_pane" "selftest should not send" "$layout_sess"; then
      _selftest_fail "send prompt refuses foreign pane" || true; rc=1
    else
      _selftest_pass "send prompt refuses foreign pane"
    fi
    if python3 - "$TOOL_ROOT/bin/relay.py" "$layout_sess" "$layout_lead" "$foreign_pane" <<'PY'
import importlib.util
import sys

path, session, owned, foreign = sys.argv[1:5]
spec = importlib.util.spec_from_file_location("roundtable_relay", path)
module = importlib.util.module_from_spec(spec)
assert spec.loader is not None
spec.loader.exec_module(module)
ok = module._pane_belongs_to_session(session, owned) and not module._pane_belongs_to_session(session, foreign)
raise SystemExit(0 if ok else 1)
PY
    then
      _selftest_pass "relay ownership check rejects foreign pane"
    else
      _selftest_fail "relay ownership check rejects foreign pane" || true; rc=1
    fi
  else
    _selftest_fail "workbench mini-build completed" || true
    rc=1
  fi

  selftest_cleanup
  trap - RETURN EXIT
  if [ "$rc" -eq 0 ]; then
    echo "  => roundtable selftest OK on this machine."
  else
    echo "  => something is off; check tmux / python3."
  fi
  return "$rc"
}

main() {
  local sub="${1:-}"; shift || true
  case "$sub" in
    init)     cmd_init     "$@" ;;
    new)      cmd_new      "$@" ;;
    start)    cmd_start    "$@" ;;
    stop)     cmd_stop     "$@" ;;
    kickoff)  cmd_kickoff  "$@" ;;
    list)     cmd_list     "$@" ;;
    _popup)   cmd_popup    "$@" ;;
    selftest) cmd_selftest "$@" ;;
    *) cat >&2 <<EOF
usage: roundtable <command>
  rt new [--start] <name> create a named idea worktree
  rt init [name|dir]      scaffold docs/design/roundtable/ + .roundtable/
  rt start [name|dir]     launch the workbench
  rt stop [name|dir]      stop this project's session
  rt kickoff [name] [xuan|su] re-send kickoff prompts (lead|impl legacy aliases)
  rt list                 list running roundtable sessions
  rt selftest             verify relay/layout/key checks on this machine (no real CLIs needed)

Each project gets its own session (roundtable-<name>-<hash>), so multiple
roundtables run concurrently. Override the name with SESSION=... if needed.

Default layout: top 玄 | 素, bottom command shell | relay watcher.
Wire labels remain lead|impl for mailbox/env compatibility; user-facing contracts are xuan|su.
Keys: prefix+g tips, prefix+e file view, prefix+v toggle mouse. Env: RT_LAYOUT=classic,
RT_MOUSE=1 (start with mouse on; off by default), RT_KEYS=0,
RT_TIPS_KEY=<key>, RT_FILE_KEY=<key>, RT_MOUSE_KEY=<key>.
Mouse is off by default (native selection works); toggle it with prefix+v when you want
wheel scroll/resize. Relay pane killed/stopped? Recover with 'roundtable stop && roundtable start'.
EOF
       exit 1 ;;
  esac
}

# Run only when executed (not when sourced, e.g. by tests).
if [ "${BASH_SOURCE[0]}" = "${0}" ]; then
  main "$@"
fi
